# Google Workspace Governance Gateway example environment
# Copy to .env for local testing. Do not commit real values.

GOOGLE_GOVERNANCE_CONTROL_AUTH_DISABLED=0
GOOGLE_GOVERNANCE_CONTROL_PORT=8095
GOOGLE_GOVERNANCE_PORT=8768

# Optional for direct non-Docker runs. Prefer Docker secrets / systemd credentials / secret manager.
# MCP hosts authenticate with GOOGLE_GOVERNANCE_ACCESS_TOKEN and identify the
# workload with GOOGLE_GOVERNANCE_AGENT_TOKEN. Generate both in the control UI;
# never commit real values.
# GOOGLE_GOVERNANCE_ACCESS_TOKEN=replace-with-ui-generated-client-token
# GOOGLE_GOVERNANCE_AGENT_TOKEN=replace-with-ui-generated-agent-token
# GOOGLE_GOVERNANCE_CONTROL_SETUP_TOKEN=replace-with-random-first-run-token
# GOOGLE_GOVERNANCE_APPROVAL_ADMIN_SECRET_PATH=/run/secrets/google_governance_approval_admin_secret
# GOOGLE_GOVERNANCE_CONTROL_SESSION_SECRET_PATH=/run/secrets/google_governance_control_session_secret
